{
  "name": "spectro-viewer",
  "version": "0.2.0-ratpenats",
  "description": "Local Ratpenats fork of SpectroViewer with canvas-rendered spectrogram data tiles.",
  "type": "module",
  "main": "dist/spectro-viewer.umd.cjs",
  "module": "dist/spectro-viewer.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/spectro-viewer.js",
      "require": "./dist/spectro-viewer.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "keywords": [
    "spectrogram",
    "viewer",
    "audio",
    "bioacoustics",
    "waveform",
    "regions",
    "annotations",
    "timeline",
    "bat-detector",
    "ultrasound"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.4"
  }
}
